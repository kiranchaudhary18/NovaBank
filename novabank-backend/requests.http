### NovaBank API Verification HTTP Requests - Phase 9
# Configured for default port 8080 and context path "/api/v1"

@baseUrl = http://localhost:8080/api/v1

# ===================================================================
# 1. SETUP / AUTHENTICATION SCENARIOS
# ===================================================================

### 1.1 Login as Default Administrator (Seeded at Startup)
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@novabank.com",
  "password": "AdminPassword123"
}

### Save Admin Token
@adminToken = {{adminLogin.response.body.data.token}}


### 1.2 Register a New Customer User Profile
# @name registerCustomer
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "fullName": "Jane Smith",
  "email": "jane.smith@novabank.com",
  "password": "Password123!",
  "phone": "+12025550188"
}


### 1.3 Login as Customer (Jane Smith)
# @name customerLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "jane.smith@novabank.com",
  "password": "Password123!"
}

### Save Customer Token and ID
@customerToken = {{customerLogin.response.body.data.token}}
@customerId = {{customerLogin.response.body.data.user.id}}


# ===================================================================
# 2. CUSTOMER & KYC FLOW SETUP
# ===================================================================

### 2.1 Create Customer Profile
# @name createCustomerProfile
POST {{baseUrl}}/customers
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Smith",
  "gender": "FEMALE",
  "dateOfBirth": "1995-06-15",
  "phoneNumber": "+12025550188",
  "email": "jane.smith@novabank.com",
  "maritalStatus": "SINGLE",
  "occupation": "Software Engineer",
  "annualIncome": 120000.00,
  "nationality": "American",
  "addresses": [
    {
      "addressType": "RESIDENTIAL",
      "houseNumber": "Apt 4B",
      "street": "123 Broadway",
      "city": "New York",
      "state": "NY",
      "country": "USA",
      "postalCode": "10001"
    }
  ]
}

### Save Customer Profile ID
@customerProfileId = {{createCustomerProfile.response.body.data.id}}


### 2.2 Submit KYC numbers
POST {{baseUrl}}/customers/kyc
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "aadhaarNumber": "200055551234",
  "panNumber": "ABCDE1234F"
}


### 2.3 Verify Customer Profile (APPROVED sets Customer to ACTIVE)
PATCH {{baseUrl}}/customers/{{customerProfileId}}/kyc/verify?status=APPROVED
Authorization: Bearer {{adminToken}}


### 2.4 Login Customer again to fetch updated profile
# @name customerLoginActive
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "jane.smith@novabank.com",
  "password": "Password123!"
}

### Save Active Customer Token
@activeCustomerToken = {{customerLoginActive.response.body.data.token}}


# ===================================================================
# 3. BANK ACCOUNT MANAGEMENT SETUP
# ===================================================================

### 3.1 Create Bank Account 1 (Savings Primary, Initial: $1000)
# @name createAccount1
POST {{baseUrl}}/accounts
Authorization: Bearer {{activeCustomerToken}}
Content-Type: application/json

{
  "customerId": "{{customerProfileId}}",
  "accountType": "SAVINGS",
  "currency": "USD",
  "branchCode": "1001",
  "isPrimary": true,
  "initialBalance": 1000.00
}

### Save Account 1 Number and ID
@account1Number = {{createAccount1.response.body.data.accountNumber}}
@account1Id = {{createAccount1.response.body.data.id}}


# ===================================================================
# 4. CARD MANAGEMENT MODULE TESTS (Phase 9)
# ===================================================================

### 4.1 Issue Physical Debit Card by Admin (VISA, PIN: 1234)
# @name issuePhysicalCard
POST {{baseUrl}}/cards/issue
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "accountNumber": "{{account1Number}}",
  "cardNetwork": "VISA",
  "pin": "1234"
}

### Save Physical Card ID
@physicalCardId = {{issuePhysicalCard.response.body.data.id}}


### 4.2 Attempt to Issue duplicate physical card on same account (Should Fail)
POST {{baseUrl}}/cards/issue
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "accountNumber": "{{account1Number}}",
  "cardNetwork": "MASTERCARD",
  "pin": "5678"
}


### 4.3 Issue Virtual Card on same account (MASTERCARD, PIN: 4321)
# @name issueVirtualCard
POST {{baseUrl}}/cards/virtual
Authorization: Bearer {{activeCustomerToken}}
Content-Type: application/json

{
  "accountNumber": "{{account1Number}}",
  "cardNetwork": "MASTERCARD",
  "pin": "4321"
}

### Save Virtual Card ID
@virtualCardId = {{issueVirtualCard.response.body.data.id}}


### 4.4 Get Cards Linked to Account
GET {{baseUrl}}/cards/account/{{account1Number}}
Authorization: Bearer {{activeCustomerToken}}


### 4.5 Freeze Virtual Card (Temporary Lock)
PATCH {{baseUrl}}/cards/freeze/{{virtualCardId}}
Authorization: Bearer {{activeCustomerToken}}


### 4.6 Try to freeze an already frozen card (Should Fail)
PATCH {{baseUrl}}/cards/freeze/{{virtualCardId}}
Authorization: Bearer {{activeCustomerToken}}


### 4.7 Unfreeze Virtual Card
PATCH {{baseUrl}}/cards/unfreeze/{{virtualCardId}}
Authorization: Bearer {{activeCustomerToken}}


### 4.8 Update Card Limits (ATM, POS, Online)
PATCH {{baseUrl}}/cards/update-limits
Authorization: Bearer {{activeCustomerToken}}
Content-Type: application/json

{
  "cardId": "{{physicalCardId}}",
  "dailyLimit": 4000.00,
  "onlineLimit": 2500.00,
  "atmLimit": 1500.00
}


### 4.9 Change Physical Card PIN Code
PATCH {{baseUrl}}/cards/change-pin
Authorization: Bearer {{activeCustomerToken}}
Content-Type: application/json

{
  "cardId": "{{physicalCardId}}",
  "oldPin": "1234",
  "newPin": "9876"
}


### 4.10 Toggle Contactless Settings
PATCH {{baseUrl}}/cards/contactless?id={{physicalCardId}}&enabled=true
Authorization: Bearer {{activeCustomerToken}}


### 4.11 Toggle International settings
PATCH {{baseUrl}}/cards/international?id={{physicalCardId}}&enabled=true
Authorization: Bearer {{activeCustomerToken}}


### 4.12 Block Physical Card permanently (Employee/Admin role required)
PATCH {{baseUrl}}/cards/block/{{physicalCardId}}?reason=Card+Lost
Authorization: Bearer {{adminToken}}


### 4.13 Replace Physical Card (Admin role required)
# Generates a new card and disables the blocked card
PATCH {{baseUrl}}/cards/replace/{{physicalCardId}}?newPin=2468
Authorization: Bearer {{adminToken}}


# ===================================================================
# 5. NOTIFICATION & EVENT-DRIVEN SYSTEM (Phase 10)
# ===================================================================

### 5.1 Fetch Notifications List for Jane Smith
GET {{baseUrl}}/notifications?page=0&size=10
Authorization: Bearer {{activeCustomerToken}}


### 5.2 Get Count of Unread Notifications
# @name unreadCount
GET {{baseUrl}}/notifications/unread
Authorization: Bearer {{activeCustomerToken}}


### 5.3 Mark all notifications as read
PATCH {{baseUrl}}/notifications/read-all
Authorization: Bearer {{activeCustomerToken}}


### 5.4 Update User Communication Preferences
PUT {{baseUrl}}/notifications/preferences
Authorization: Bearer {{activeCustomerToken}}
Content-Type: application/json

{
  "emailEnabled": false,
  "inAppEnabled": true
}


# ===================================================================
# 6. ENTERPRISE ADMIN DASHBOARD & REPORTING (Phase 12)
# ===================================================================

### 6.1 Get Admin Dashboard summary KPIs (Admin restricted)
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{adminToken}}


### 6.2 Try to access Admin Dashboard using Customer Token (Should Fail with 403 Forbidden)
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{activeCustomerToken}}


### 6.3 Get Customer Registration analytics
GET {{baseUrl}}/admin/analytics/customers
Authorization: Bearer {{adminToken}}


### 6.4 Get Accounts status distribution metrics
GET {{baseUrl}}/admin/analytics/accounts
Authorization: Bearer {{adminToken}}


### 6.5 Get Transaction volume and extremes metrics
GET {{baseUrl}}/admin/analytics/transactions
Authorization: Bearer {{adminToken}}


### 6.6 Get physical vs virtual Cards stats
GET {{baseUrl}}/admin/analytics/cards
Authorization: Bearer {{adminToken}}


### 6.7 Get stubbed Loans metrics
GET {{baseUrl}}/admin/analytics/loans
Authorization: Bearer {{adminToken}}


### 6.8 Download Customers report in PDF format
GET {{baseUrl}}/admin/reports/customers?format=PDF
Authorization: Bearer {{adminToken}}


### 6.9 Download Accounts report in CSV format
GET {{baseUrl}}/admin/reports/accounts?format=CSV
Authorization: Bearer {{adminToken}}


### 6.10 Download Transactions report in CSV format
GET {{baseUrl}}/admin/reports/transactions?format=CSV
Authorization: Bearer {{adminToken}}


### 6.11 Download Revenue streams report in PDF format
GET {{baseUrl}}/admin/reports/revenue?format=PDF
Authorization: Bearer {{adminToken}}


# ===================================================================
# 7. ENTERPRISE FRAUD DETECTION & AUDIT SYSTEM (Phase 13)
# ===================================================================

### 7.1 Fetch Paginated Audit Logs (Admin restricted)
GET {{baseUrl}}/admin/audit?page=0&size=10&status=SUCCESS
Authorization: Bearer {{adminToken}}


### 7.2 Fetch Triggered Fraud Alerts
# @name fraudAlerts
GET {{baseUrl}}/admin/fraud-alerts?page=0&size=10&status=OPEN
Authorization: Bearer {{adminToken}}


### 7.3 Fetch Customer Risk Score Profile
GET {{baseUrl}}/admin/security/risk-score/{{customerProfileId}}
Authorization: Bearer {{adminToken}}



